{
	"name": "learn-hono6-awslambda",
	"version": "0.1.1",
	"bin": {
		"learn-hono6-awslambda": "bin/learn-hono6-awslambda.js"
	},
	"scripts": {
		"build": "tsc",
		"watch": "tsc -w",
		"test": "jest",
		"cdk": "cdk",
		"preinstall": "bun audit",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix",
		"list": "cdk list",
		"deploy": "cdk deploy --outputs-file outputs.json",
		"bootstrap": "cdk bootstrap",
		"diff": "cdk diff",
		"destroy": "cdk destroy",
		"dev": "tsx watch script/node.ts"
	},
	"dependencies": {
		"aws-cdk-lib": "2.257.0",
		"constructs": "^10.6.0",
		"date-fns": "^4.3.0",
		"hono": "^4.12.23",
		"source-map-support": "^0.5.21"
	},
	"devDependencies": {
		"@hono/node-server": "^2.0.4",
		"@types/jest": "^30.0.0",
		"@types/node": "25.9.1",
		"aws-cdk": "2.1124.1",
		"esbuild": "^0.28.0",
		"jest": "^30.4.2",
		"ts-jest": "^29.4.11",
		"ts-node": "^10.9.2",
		"tsx": "^4.22.3",
		"typescript": "~6.0.3"
	}
}
